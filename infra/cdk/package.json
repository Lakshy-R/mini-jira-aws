    "synth":  "cdk synth"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "typescript":  "^5.8.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.200.0",
    "constructs":  "^10.4.2"
  }
}
