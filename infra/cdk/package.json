{
  "name": "mini-jira-cdk",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for Mini-Jira",
  "main": "bin/app.js",
  "scripts": {
    "build":  "tsc",
    "watch":  "tsc -w",
