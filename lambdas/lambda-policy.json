{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3Read",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::mini-jira-originals-laksh-2026/*"
    },
    {
      "Sid": "S3WriteResized",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::mini-jira-resized-laksh-2026/*"
    },
    {
      "Sid": "DynamoUpdateTask",
      "Effect": "Allow",
      "Action": ["dynamodb:UpdateItem", "dynamodb:Scan"],
      "Resource": "arn:aws:dynamodb:eu-north-1:*:table/Tasks"
    }
  ]
}
